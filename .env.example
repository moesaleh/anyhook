# Application
PORT=3001
NODE_ENV=development

# Server-side pepper for hashing 2FA backup codes. When set, codes are
# stored as HMAC-SHA256(pepper, code) instead of plain SHA-256, so a
# DB-only leak can't be brute-forced. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# and rotate by re-issuing backup codes (existing codes hashed with the
# old pepper become invalid).
# BACKUP_CODE_PEPPER=please_change_me_to_a_long_random_string

# Envelope-encryption key for users.totp_secret (AES-256-GCM, derived
# via scrypt). Must be at least 32 chars. When unset, TOTP secrets are
# stored plaintext (acceptable for dev / tests, NOT production). Generate
# one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Rotation: set the OLD value as TOTP_SECRET_KEY_OLD and the NEW one as
# TOTP_SECRET_KEY. The auth code falls back to the old key on read +
# automatically re-encrypts to the new key on the next verify, so no
# downtime / migration script. Once all rows have been touched, drop
# TOTP_SECRET_KEY_OLD.
# TOTP_SECRET_KEY=please_change_me_to_a_long_random_string
# TOTP_SECRET_KEY_OLD=

# Dashboard
DASHBOARD_URL=http://localhost:3000
DASHBOARD_PORT=3000

# SMTP for sending invitation + password-reset emails. Without these,
# the API returns the raw tokens in responses (dev convenience). With
# them, the user receives the link in their inbox and the API omits
# the token from the response.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_SECURE=false
# EMAIL_FROM=noreply@anyhook.local
# TOTP_ISSuer=AnyHook

# JWT secret for signing dashboard session cookies (REQUIRED).
# Must be at least 32 characters. Rotate by redeploying with a new value
# (will invalidate all existing sessions; users have to log in again).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_32_characters

# Admin API Key (REQUIRED to enable admin/debug endpoints)
# Without this, DELETE /subscriptions, /redis/*, and /kafka/topics/* return 503.
# ADMIN_API_KEY=your_secret_admin_key_here

# SSRF protection: by default, webhook_url and args.endpoint_url cannot point
# at loopback (127.x), private (10/172.16/192.168), link-local (169.254),
# CGNAT (100.64/10), or IPv6 ULA/link-local addresses. Set to 'true' to allow
# them — only do this in local development.
# ALLOW_PRIVATE_WEBHOOK_TARGETS=false

# Logging level — error | warn | info | debug. Default 'info'.
# Production defaults to JSON output; development to colored single-line.
# LOG_LEVEL=info

# Internal HTTP port for /metrics + /health. Used by ALL three services
# (subscription-management, subscription-connector, webhook-dispatcher).
# Not exposed publicly via docker-compose; only reachable inside the
# docker network. /metrics used to live on the main API port (3001) for
# subscription-management — moving it here closes a metrics-leak surface.
# METRICS_PORT=9090

# Webhook retry queue tuning (webhook-dispatcher)
# RETRY_POLL_INTERVAL_MS=30000
# RETRY_BATCH_SIZE=25
# RETRY_LOCK_TIMEOUT_MS=300000

# Per-org HTTP API rate limit (subscription-management). 600 req/60s/org by
# default. Counted per (organization_id, time-bucket) in Redis.
# RATE_LIMIT_REQUESTS=600
# RATE_LIMIT_WINDOW_SEC=60

# In-memory cache TTL (ms) for the per-org rate-limit override row. The
# middleware would otherwise issue one PG roundtrip per authenticated
# request to read organizations.rate_limit_requests / _window_sec; with
# the cache it's ~1 roundtrip per org per TTL window. Operators flipping
# an override see it apply within this many ms.
# RATE_LIMIT_OVERRIDE_TTL_MS=5000

# RATE_LIMIT_PER_USER=true switches the rate-limit key from per-org to
# per-user-per-org. A noisy admin polling the dashboard won't consume
# the whole org's budget; each member is counted independently. API-
# key auth (no userId) still falls back to per-org so robots can't
# bypass the limit. Disabled by default — turn on when the per-user
# shape matches your product policy.
# RATE_LIMIT_PER_USER=false

# Per-IP rate limit for /auth/login + /auth/register. Stricter than the
# per-org limit because anonymous endpoints are the primary credential-
# stuffing surface. Defaults to 10 req/60s/IP.
# AUTH_RATE_LIMIT_REQUESTS=10
# AUTH_RATE_LIMIT_WINDOW_SEC=60

# Per-organization standing quotas (caps total usage, not request rate).
# - Subscriptions per org. Default 100.
# - Active API keys per org (revoked don't count). Default 10.
# Future: per-org overrides via an organizations.max_* column.
# ORG_MAX_SUBSCRIPTIONS=100
# ORG_MAX_API_KEYS=10

# Trust proxy hops for X-Forwarded-For (and req.ip). Set to '1' or 'true'
# behind a single reverse proxy (nginx/ALB/Cloudflare); set to a number for
# multi-hop setups. Default: false (assume direct client connections).
# TRUST_PROXY=1

# Bitquery streaming token (only required for src/test/graphql/client.js)
# BITQUERY_TOKEN=your_bitquery_token_here

# Bind address for the Postgres / Redis / Kafka ports published by
# docker-compose. Defaults to 127.0.0.1 so the data tier is reachable
# for local dev tooling but NOT exposed on the public network. Set to
# 0.0.0.0 only if you actually need external access (and harden the
# credentials accordingly).
# DATA_BIND=127.0.0.1

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=subscriptions_db
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://default:password@localhost:${REDIS_PORT}

# Kafka Configuration
KAFKA_PORT=9092
KAFKA_HOST=localhost:${KAFKA_PORT}
KAFKA_NODE_ID=0
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_QUORUM_VOTERS=0@kafka:9093

# Kafka topic shape — controls connector + dispatcher horizontal scaling.
# Producers set key=subscriptionId so the same sub always lands on the same
# partition; up to N consumer pods can run in parallel (one per partition).
# After increasing for an EXISTING topic, you also need
# `kafka-topics.sh --alter --partitions N` against each topic.
# KAFKA_PARTITIONS=8
# KAFKA_REPLICATION_FACTOR=1

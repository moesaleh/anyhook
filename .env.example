# Application
PORT=3001
NODE_ENV=development

# Dashboard
DASHBOARD_URL=http://localhost:3000
DASHBOARD_PORT=3000

# JWT secret for signing dashboard session cookies (REQUIRED).
# Must be at least 32 characters. Rotate by redeploying with a new value
# (will invalidate all existing sessions; users have to log in again).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_32_characters

# Admin API Key (REQUIRED to enable admin/debug endpoints)
# Without this, DELETE /subscriptions, /redis/*, and /kafka/topics/* return 503.
# ADMIN_API_KEY=your_secret_admin_key_here

# SSRF protection: by default, webhook_url and args.endpoint_url cannot point
# at loopback (127.x), private (10/172.16/192.168), link-local (169.254),
# CGNAT (100.64/10), or IPv6 ULA/link-local addresses. Set to 'true' to allow
# them — only do this in local development.
# ALLOW_PRIVATE_WEBHOOK_TARGETS=false

# Bitquery streaming token (only required for src/test/graphql/client.js)
# BITQUERY_TOKEN=your_bitquery_token_here

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=subscriptions_db
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://default:password@localhost:${REDIS_PORT}

# Kafka Configuration
KAFKA_PORT=9092
KAFKA_HOST=localhost:${KAFKA_PORT}
KAFKA_NODE_ID=0
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_QUORUM_VOTERS=0@kafka:9093
